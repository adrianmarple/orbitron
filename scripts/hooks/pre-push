#!/bin/bash
# Auto-build Arduino firmware if arduino/esp32/ files changed in this push.
# Runs in the background so the push is not blocked.
CHANGED=false
while read local_ref local_sha remote_ref remote_sha; do
  # remote_sha is zeros when pushing a new branch (no upstream yet)
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha --not --remotes=origin"
  else
    range="$remote_sha..$local_sha"
  fi

  if git log --name-only --format="" $range -- arduino/esp32/ | grep -q .; then
    CHANGED=true
  fi
done

if [ "$CHANGED" = true ]; then
  echo "arduino/esp32/ changed, building and uploading firmware in background..."
  nohup bash scripts/arduino_build.sh > /tmp/arduino_build.log 2>&1 &
  disown
  echo "Build started. Follow progress: tail -f /tmp/arduino_build.log"
fi
